{
  "name": "tarot-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Tarot Platform Monorepo base setup",
  "scripts": {
    "backend:dev": "npm run start:dev -w @tarot-platform/backend",
    "backend:build": "npm run build -w @tarot-platform/backend",
    "web:dev": "npm run dev -w @tarot-platform/web --",
    "web:build": "npm run build -w @tarot-platform/web",
    "web:preview": "npm run preview -w @tarot-platform/web --",
    "mobile:start": "npm run start -w @tarot-platform/mobile",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "prisma": {
    "seed": "ts-node apps/backend/prisma/seed.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "18": "^0.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
