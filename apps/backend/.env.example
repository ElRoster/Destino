# Database Connection (Prisma)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5433/destino?schema=public"

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Config
JWT_ACCESS_SECRET="change_me_access_secret"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_SECRET="change_me_refresh_secret"
JWT_REFRESH_EXPIRATION="7d"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Backend Server Config
PORT=4020
NODE_ENV=development

# App URLs
# CLIENT_URL is where users return after confirming their email.
# API_URL is used to build the confirmation link sent by email.
CLIENT_URL="http://localhost:5173"
API_URL="http://localhost:4020"

# SMTP Email Configuration
# Example for Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-google-app-password
# SMTP_FROM="Destino <your-email@gmail.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Destino <no-reply@destino.local>"
SMTP_HELO=localhost
