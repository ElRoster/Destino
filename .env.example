# Environment configuration template for Tarot Platform

# Backend Server Config
PORT=4020
API_URL="http://localhost:4020"
NODE_ENV=development

# Database Connection (Prisma)
# local postgres via docker-compose
DATABASE_URL="postgresql://tarot_user:tarot_secure_password@localhost:5432/tarot_db?schema=public"

# Redis Config
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Config
JWT_ACCESS_SECRET="tarot_super_secret_access_key_2026_change_me_in_production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_SECRET="tarot_super_secret_refresh_key_2026_change_me_in_production"
JWT_REFRESH_EXPIRATION="7d"

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Client Configuration
CLIENT_URL="http://localhost:5173"
VITE_API_BASE_URL="http://localhost:4020"
